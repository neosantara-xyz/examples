# E2B sandbox build (https://e2b.dev/dashboard)
E2B_API_KEY="YOUR_E2B_API_KEY_HERE"

# Telegram bot token from @BotFather
TELEGRAM_TOKEN="YOUR_TELEGRAM_BOT_TOKEN_HERE"

# Neosantara API key (https://api.neosantara.xyz) — read by Agno's Neosantara model
NEOSANTARA_API_KEY="YOUR_NEOSANTARA_API_KEY_HERE"

# Optional overrides (both runtimes)
# NEOSANTARA_MODEL="gemini-3-flash"
# AGENT_INSTRUCTIONS="You are a helpful assistant chatting over Telegram."

# --- bot.py (long-poll) only ---
# ALLOWED_CHAT_IDS="123456789,987654321"

# --- agentos_server.py (AgentOS webhook) only ---
# PORT="7777"
# APP_ENV="development"                 # skips webhook secret checks for local/dev
# TELEGRAM_WEBHOOK_SECRET_TOKEN=""      # required in production
# SESSION_DB_FILE="/tmp/telegram_sessions.db"
